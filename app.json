{
  "expo": {
    "name": "Fut Manager Pocket",
    "slug": "futmanager-pocket",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "futmanager",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.futmanager.pocket"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a3a2a",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.futmanager.pocket"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "name": "Fut Manager Pocket",
      "shortName": "FutManager",
      "description": "Quiz de futebol + coleção de cartas + gestão de time",
      "themeColor": "#050f0a",
      "backgroundColor": "#050f0a",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
